# Canonical site origin used by metadata (canonical/OG URLs), robots.txt and the
# sitemap. No trailing slash. Copy this file to .env and adjust as needed; set the
# same variable in your hosting provider for production.
NEXT_PUBLIC_SITE_URL=https://advisory.wtp.vn

# Google Search Console site verification token. Rendered into <head> as the
# <meta name="google-site-verification"> tag. Server-only (not exposed to the
# client). Set the same variable in your hosting provider for production.
GOOGLE_SITE_VERIFICATION=
