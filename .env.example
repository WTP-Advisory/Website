# Canonical site origin used by metadata (canonical/OG URLs), robots.txt and the
# sitemap. No trailing slash. Copy this file to .env and adjust as needed; set the
# same variable in your hosting provider for production.
NEXT_PUBLIC_SITE_URL=https://advisory.wtp.vn

# Google Search Console site verification token(s). Rendered into <head> as
# <meta name="google-site-verification"> tags. Server-only (not exposed to the
# client). Set the same variables in your hosting provider for production.
GOOGLE_SITE_VERIFICATION=
GOOGLE_SITE_VERIFICATION_2=

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Exposed to the client.
# Set the same variable in your hosting provider for production.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
